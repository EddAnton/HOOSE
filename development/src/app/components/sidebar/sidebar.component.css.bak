:host {
	--color-light: #f6f6f9;

	--linear-gradient-background: linear-gradient(195deg, #42424a 0%, #191919 100%);
	--linear-gradient-light-hr: linear-gradient(90deg, rgba(255, 255, 255, 0), #fff, rgba(255, 255, 255, 0));
	--linear-gradient-option-active: linear-gradient(195deg, #ec407a, #d81b60);

	/* Variables responsive */
	--sidebar-header-font-size: 1.1rem;
	--sidebar-menu-option-font-size: 0.85rem;
	--sidebar-menu-option-counter-font-size: 0.7rem;
	--sidebar-menu-option-a-width: 90%;
	--sidebar-menu-option-menu-option-icon-pl: 20px;
}

.sidebar-container {
	height: 100%;
	display: flex;
	color: var(--color-light);
}

.sidebar {
	width: 98%;
	margin: 6px auto 6px;
	background: var(--linear-gradient-background);
	border-radius: 0.8rem;
	box-shadow: 1px 1px 1px rgba(0, 0, 0, 0.5);
	overflow: hidden;
	display: flex;
	flex-direction: column;
}

/* Header */
.sidebar .header {
	flex: 0 0 60px;
	margin: 10px 5px 0 5px;
	display: flex;
	flex-direction: column;
	align-items: center;
	font-size: var(--sidebar-header-font-size);
}

.sidebar .header .brand {
	text-align: center;
	margin: 10px auto;
	display: flex;
	align-items: center;
}

.sidebar .header .brand .brand-title {
	padding-left: 5px;
}

.sidebar .header .version {
	font-size: 0.6rem;
	margin-top: -14px;
	margin-bottom: 4px;
}

.sidebar .header hr {
	width: 100%;
	margin: 0;
	background-color: transparent;
	background-image: var(--linear-gradient-light-hr);
	border-top: none;
	height: 1px;
}

/* Menu options */
.sidebar .menu-options {
	width: 98%;
	margin: auto;
	flex: 1 1 auto;
	display: flex;
	flex-direction: column;
	overflow-y: auto;
}

.sidebar .menu-options .menu-option {
	/* flex: 0 0 2.5rem; */
	flex: 0 0 auto;
	display: flex;
	align-items: center;
	padding-top: 2px;
	padding-bottom: 2px;
	position: relative;
}

.sidebar .menu-options .menu-option .menu-divider {
	width: 100%;
	margin: 4px auto;
	height: 5px;
	display: flex;
	align-items: center;
	/* justify-content: center; */
}

.sidebar .menu-options .menu-option .menu-divider hr {
	width: 80%;
	margin: auto 10px;
	background-color: transparent;
	background-image: var(--linear-gradient-light-hr);
	border: none;
	height: 1px;
}

.sidebar .menu-options .menu-option a {
	color: white;
	text-decoration: none;
	font-size: var(--sidebar-menu-option-font-size);
	height: 2.5rem;
	width: var(--sidebar-menu-option-a-width);
	margin: auto;
	display: flex;
	align-items: center;
	border-radius: 0.4rem;
	transition: color 0.15s ease-in-out, background-color 0.15s ease-in-out, border-color 0.15s ease-in-out;
}

.sidebar .menu-options .menu-option a .menu-option-icon {
	padding-left: var(--sidebar-menu-option-menu-option-icon-pl);
}

.sidebar .menu-options .menu-option a .menu-option-title {
	padding-left: 0.5rem;
	font-weight: 500;
}

.sidebar .menu-options .menu-option.active a {
	background: var(--linear-gradient-option-active);
}

.sidebar .menu-options .menu-option:not(.active) a:hover {
	background: #525257;
}

.sidebar .menu-options .menu-option a .menu-option-counter {
	background: var(--color-danger);
	color: var(--color-white);
	margin-left: 10px;
	padding: 2px 10px;
	font-size: var(--sidebar-menu-option-counter-font-size);
	border-radius: 0.4rem;
}

@media screen and (max-width: 640px) {
	:host {
		--sidebar-header-font-size: 0.9rem;
		--sidebar-menu-option-font-size: 0.7rem;
		--sidebar-menu-option-counter-font-size: 0.6rem;
		--sidebar-menu-option-a-width: 98%;
		--sidebar-menu-option-menu-option-icon-pl: 2px;
	}
}

@media screen and (max-width: 800px) {
	:host {
		--sidebar-header-font-size: 1rem;
		--sidebar-menu-option-font-size: 0.8rem;
		--sidebar-menu-option-counter-font-size: 0.7rem;
		--sidebar-menu-option-a-width: 94%;
		--sidebar-menu-option-menu-option-icon-pl: 8px;
	}
}
