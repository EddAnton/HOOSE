.card .p-datatable .p-datatable-header {
	border-top-left-radius: 0.375rem;
	border-top-right-radius: 0.375rem;
}
.card .p-datatable .p-datatable-thead > tr > th:first-child {
	border-top-left-radius: 0.375rem;
}
.card .p-datatable .p-datatable-thead > tr > th:last-child {
	border-top-right-radius: 0.375rem;
}
.card .p-datatable .p-datatable-tbody > tr:last-child > td:first-child {
	border-bottom-left-radius: 0.375rem;
}
.card .p-datatable .p-datatable-tbody > tr:last-child > td:last-child {
	border-bottom-right-radius: 0.375rem;
}
